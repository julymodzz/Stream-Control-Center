# Server
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
POLL_INTERVAL_MS=5000
NODE_ENV=development
DATA_DIR=./data
TRUST_PROXY=0
LOG_LEVEL=info
CORS_ORIGIN=*

# Sicherheit (PFLICHT in Produktion – min. 32 Zeichen)
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CSRF_SECRET=change-me-to-another-random-string-32-chars

# Rate Limiting & Brute-Force-Schutz
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_DURATION_MS=900000

# Standard-Admin (nur bei Erstinstallation)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme-on-first-login

# Mock-Modus
MOCK_MODE=false
PROC_PATH=/proc

# OBS
OBS_SERVICE_NAME=obs
OBS_LOG_PATH=/var/log/obs/obs.log
OBS_WEBSOCKET_HOST=127.0.0.1
OBS_WEBSOCKET_PORT=4455
OBS_WEBSOCKET_PASSWORD=

# NOALBS
NOALBS_SERVICE_NAME=noalbs
NOALBS_LOG_PATH=/var/log/noalbs/noalbs.log

# Netzwerküberwachung
PING_TARGETS=8.8.8.8,twitch.tv,google.com
PING_TIMEOUT_MS=3000
HIGH_LATENCY_THRESHOLD_MS=200
HIGH_PACKET_LOSS_THRESHOLD=10

# Alert-Schwellwerte
HIGH_CPU_THRESHOLD=90
HIGH_RAM_THRESHOLD=90
DISK_FULL_THRESHOLD=90
NOTIFICATION_MAX_HISTORY=100
METRICS_HISTORY_SIZE=120

# Benachrichtigungen (optional)
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Backup
BACKUP_RETENTION_COUNT=10
BACKUP_SCHEDULE_CRON=0 3 * * *

# Frontend (Entwicklung)
VITE_API_URL=
